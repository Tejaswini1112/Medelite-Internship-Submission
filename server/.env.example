# Server configuration
PORT=4000

# Comma-separated list of allowed CORS origins (frontend URLs).
# Use * for local development convenience.
CORS_ORIGIN=http://localhost:5173

# Optional API key for internal use. If set, clients must send it as
# the `x-api-key` header (or ?api_key= query param). Leave blank to disable.
API_KEY=

# Cache TTL for CMS responses, in seconds (rate-limit smoothing).
CACHE_TTL_SECONDS=3600

# Upstream CMS request timeout (ms) and retry policy.
CMS_TIMEOUT_MS=30000
CMS_MAX_RETRIES=3
