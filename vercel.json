{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build -w client",
  "outputDirectory": "client/dist",
  "installCommand": "npm install",
  "functions": {
    "api/report/pdf.ts": {
      "maxDuration": 60,
      "includeFiles": "node_modules/@sparticuz/chromium/**"
    },
    "api/report/docx.ts": { "maxDuration": 30 },
    "api/facility/[ccn].ts": { "maxDuration": 30 }
  }
}
